<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- iOS Universal Links: associate the app with telecinema.runasp.net so a
	     shared https room link opens the app. Verified against
	     https://telecinema.runasp.net/.well-known/apple-app-site-association -->
	<key>com.apple.developer.associated-domains</key>
	<array>
		<string>applinks:telecinema.runasp.net</string>
	</array>
</dict>
</plist>
